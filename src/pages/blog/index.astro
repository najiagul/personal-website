---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title="Blog — Najia Gul"
  description="Notes on building AI products: evals, shipping cadence, and the gap between demo and daily use."
>
  <section class="wrap">
    <span class="hand label">writing</span>
    <h1>Notes on building AI products</h1>

    {
      posts.length === 0 ? (
        <div class="card empty">
          <span class="hand hand--teal">first post coming soon —</span>
          <p>
            I'm writing about building AI products: evals, shipping cadence, and the gap
            between demo and daily use. Until then, my inbox is open —
            <a class="link-quiet" href="mailto:najiagul.2000@gmail.com">
              najiagul.2000@gmail.com
            </a>
          </p>
        </div>
      ) : (
        <div class="posts">
          {posts.map((post) => (
            <a class="post card reveal" href={`/blog/${post.id}/`}>
              <span class="pt">{post.data.title}</span>
              <span class="pd">{post.data.description}</span>
              <span class="pm">{fmt(post.data.pubDate)}</span>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Base>

<style>
  section { margin-top: 64px; }
  .label { font-size: 1.4rem; margin-bottom: 12px; }
  h1 { font-size: clamp(2rem, 4.4vw, 2.8rem); max-width: 20ch; }

  .empty { margin-top: 36px; padding: 36px 40px; max-width: 620px; }
  .empty .hand--teal { font-size: 1.35rem; }
  .empty p { margin-top: 12px; color: var(--body); }

  .posts { margin-top: 36px; display: grid; gap: 22px; max-width: 620px; }
  .post {
    display: block;
    text-decoration: none;
    padding: 26px 28px;
    border-radius: 16px;
    box-shadow: 4px 4px 0 var(--teal);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .post:hover { transform: translate(2px, 2px); box-shadow: 2px 2px 0 var(--teal); }
  .pt {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
    line-height: 1.3;
  }
  .pd { display: block; margin-top: 8px; color: var(--body); font-size: 0.95rem; }
  .pm { display: block; margin-top: 12px; font-size: 0.88rem; color: var(--muted); font-weight: 500; }

  @media (max-width: 640px) {
    .empty { padding: 28px 24px; }
  }
</style>
