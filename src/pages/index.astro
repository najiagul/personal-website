---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const email = 'najiagul.2000@gmail.com';
// Web3Forms public access key — safe to ship in client HTML. It only permits
// delivering form submissions to the registered inbox; rotate at web3forms.com.
const web3formsKey = '36990791-ebf0-45ae-8df6-ce639f350422';

const experience = [
  {
    when: 'now',
    whenAccent: true,
    role: 'Product Manager',
    note: 'Helping product teams do their best work, on the Product Excellence team.',
    company: 'SAP',
  },
  {
    when: 'before',
    whenAccent: false,
    role: 'Data Science Consultant',
    note: 'Building AI solutions end to end, from first idea to launch.',
    company: 'IBM',
  },
  {
    when: 'a while',
    whenAccent: false,
    role: 'Technical Writer',
    note: "Turning complex concepts into clear, compelling stories for each brand's voice.",
    company: 'Microsoft · Meta · Red Hat · CircleCI',
  },
];

const approach = [
  {
    n: '01',
    title: 'Immersion',
    body: 'The first weeks go deep into your product, users, and metrics — so everything after rests on real context.',
  },
  {
    n: '02',
    title: 'Find where users stall',
    body: 'Interviews and your own usage data, turned into a ranked list of fixes your team can start on immediately.',
  },
  {
    n: '03',
    title: 'Product specifications',
    body: 'Small, tightly scoped releases, written so engineering can start building without a clarification round.',
  },
  {
    n: '04',
    title: 'Evals from day one',
    body: 'A runnable definition of "good" for every AI feature, with a suite that keeps working long after the engagement ends.',
  },
  {
    n: '05',
    title: 'Hands-on when it helps',
    body: "I don't stay in the doc! When the team is stretched, I build alongside your engineers: prototypes, eval pipelines, the plumbing around the model.",
  },
];

// Motto marquee: one half repeated twice for a seamless -50% loop.
const mottoPhrases = ['bridge the gap', 'translate the complex', 'build with intention'];
const mottoHalf = Array.from({ length: 4 }, () => mottoPhrases).flat();
---

<Base
  title="Najia Gul — fractional product manager for AI teams"
  description="I help teams turn complicated technology into products people can understand, trust, and love — a fractional PM, former data scientist, currently at SAP."
>
  <!-- ============ top bar ============ -->
  <header class="topbar">
    <a href="#top" class="logo">najia gul</a>
    <nav class="nav">
      <a href="#about">about</a>
      <a href="#say-hi">say hi</a>
    </nav>
  </header>

  <!-- ============ hero ============ -->
  <section id="top" class="hero">
    <div class="hero-copy">
      <h1 class="fade-up" style="--delay: 0.1s">
        Hi, I'm Najia — I help teams turn complicated technology into products people can
        <span class="cycle" data-cycle><span class="cycle-word" data-cycle-word>understand</span>.</span>
      </h1>
      <p class="hero-sub fade-up" style="--delay: 0.22s">
        Most of my work is translation. I close the gap between the people who build the
        technology and the people who use it.
      </p>
    </div>

    <figure class="portrait fade-up" style="--delay: 0.34s">
      <div class="portrait-block" aria-hidden="true"></div>
      <div class="portrait-frame">
        <img
          src={`${base}/najia-portrait.jpg`}
          alt="Najia Gul"
          width="900"
          height="1125"
        />
      </div>
    </figure>
  </section>

  <!-- ============ scrolling motto ============ -->
  <div class="motto" aria-hidden="true">
    <div class="motto-track">
      {
        [0, 1].map(() => (
          <div class="motto-half">
            {mottoHalf.map((phrase, i) => (
              <span class="motto-item" data-tone={i % 3}>
                {phrase}
                {/* U+FE0E forces text (non-emoji) rendering so iOS Safari
                    doesn't turn the asterisk into a green emoji glyph */}
                <span class="motto-star">{'✳︎'}</span>
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </div>

  <!-- ============ about ============ -->
  <section id="about" class="colset">
    <div class="eyebrow reveal">a little<br />about me</div>
    <div class="colset-body reveal">
      <p class="lead">
        I'm currently based in Germany and work as a product manager at
        <em>SAP.</em>&nbsp;I help product teams achieve excellence and build stronger
        ecosystems by bridging the gap between technical capabilities and product impact.
      </p>
      <p class="body">
        Before SAP, I was a data science consultant at IBM, building AI solutions end to end.
        I'm also a hobbyist writer — I've written whitepapers and developer guides for
        Microsoft, Meta, Red Hat, CircleCI, and more, translating complex AI concepts into
        clear, compelling content shaped to each brand's own voice.
      </p>
      <p class="body">My motto is to build things in this world with intention.</p>
    </div>
  </section>

  <!-- ============ experience ============ -->
  <section id="adventures" class="experience">
    <h2 class="section-head">Experience</h2>
    <div class="rows">
      {
        experience.map((job) => (
          <div class="exp-row reveal">
            <div class:list={['exp-when', { accent: job.whenAccent }]}>{job.when}</div>
            <div class="exp-main">
              <div class="exp-role">{job.role}</div>
              <div class="exp-note">{job.note}</div>
            </div>
            <div class="exp-company">
              <span class="company-mark">{job.company}</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ these days ============ -->
  <section id="now" class="colset">
    <div class="eyebrow reveal">these<br />days</div>
    <div class="colset-body reveal">
      <p class="lead">
        I'm most interested in <em>trustworthy, safe AI</em> — particularly how it's reshaping
        society, and what that means for all of us.
      </p>
      <p class="body">
        I'm also fascinated by startups, entrepreneurship, and the creator economy. My
        curiosity gravitates toward any meaningful intersection of technology with other
        disciplines, and I get easily excited by ideas that challenge conventional thinking.
      </p>
    </div>
  </section>

  <!-- ============ say hi / contact ============ -->
  <section id="say-hi" class="sayhi">
    <div class="sayhi-inner">
      <!-- lead-in -->
      <div class="sayhi-lead">
        <div class="eyebrow">let's work together</div>
        <h2 class="sayhi-head">
          Currently open to <em>fractional PM</em> engagements.
        </h2>
        <p class="hero-sub">
          If you're shipping something ambitious — especially with AI in the mix — and want a
          product partner who can go deep fast and leave your team better than they found it,
          let's talk. Here's how I like to work.
        </p>
      </div>

      <!-- approach -->
      <div class="colset approach">
        <div class="eyebrow">my approach<br />to work</div>
        <div class="approach-body">
          {
            approach.map((item) => (
              <div class="approach-row reveal">
                <div class="approach-n">{item.n}</div>
                <div>
                  <div class="approach-title">{item.title}</div>
                  <div class="approach-desc">{item.body}</div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- contact form -->
      <div class="colset">
        <div class="eyebrow">say<br />hi</div>
        <form
          class="card"
          data-contact
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="Fractional PM — let's talk" data-subject-field />
          <input type="hidden" name="from_name" value="najiagul.com contact form" />
          <!-- honeypot: bots fill this, humans never see it -->
          <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

          <div class="card-row card-row--to">
            <label>To</label>
            <span class="card-to">{email}</span>
            <button type="button" class="copy-btn" data-copy={email}>Copy</button>
          </div>
          <div class="card-row">
            <label for="from">From</label>
            <input id="from" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="card-row">
            <label for="subject">Subject</label>
            <input id="subject" type="text" />
          </div>
          <div class="card-row card-row--message">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" required></textarea>
          </div>
          <div class="card-send">
            <button type="submit" class="send-btn">Send ↗</button>
            <p class="form-status" data-status role="status" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ============ footer ============ -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-line">
        building things with <em>intention</em>, and curiosity.
      </div>
      <div class="footer-meta">© {new Date().getFullYear()} Najia Gul</div>
    </div>
  </footer>
</Base>

<script is:inline>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- hero cycling word ---------- */
  (() => {
    const cycle = document.querySelector('[data-cycle]');
    const wordEl = document.querySelector('[data-cycle-word]');
    if (!cycle || !wordEl) return;
    const words = ['understand', 'trust', 'use', 'love', 'believe in'];

    // Reserve the width of the widest word so the sentence always wraps the
    // same way — the cycling word stays on the last line instead of hopping
    // up a line when a shorter word (e.g. "use") is shown.
    const reserve = () => {
      const cs = getComputedStyle(wordEl);
      const probe = document.createElement('span');
      probe.style.cssText =
        'position:absolute;visibility:hidden;white-space:nowrap;' +
        `font:${cs.fontStyle} ${cs.fontWeight} ${cs.fontSize}/${cs.lineHeight} ${cs.fontFamily};` +
        `letter-spacing:${cs.letterSpacing};`;
      document.body.appendChild(probe);
      let max = 0;
      for (const w of words) {
        probe.textContent = w;
        max = Math.max(max, probe.getBoundingClientRect().width);
      }
      probe.remove();
      cycle.style.minWidth = Math.ceil(max) + 'px';
    };
    reserve();
    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(reserve, 150);
    });

    // Swap text on the same styled element (keeps its scoped blue + yellow).
    if (reduce) return;
    let i = 0;
    setInterval(() => {
      i = (i + 1) % words.length;
      wordEl.textContent = words[i];
      wordEl.style.animation = 'none';
      void wordEl.offsetWidth; // restart the entrance animation
      wordEl.style.animation = 'word-in 0.55s cubic-bezier(.2, .7, .2, 1) both';
    }, 2600);
  })();

  /* ---------- scroll reveal ---------- */
  (() => {
    if (reduce || !('IntersectionObserver' in window)) {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in-view'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -12% 0px', threshold: 0.15 }
    );
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  })();

  /* ---------- copy email ---------- */
  (() => {
    const btn = document.querySelector('[data-copy]');
    if (!btn) return;
    let t;
    btn.addEventListener('click', () => {
      const value = btn.getAttribute('data-copy');
      if (navigator.clipboard) navigator.clipboard.writeText(value).catch(() => {});
      btn.textContent = 'Copied';
      clearTimeout(t);
      t = setTimeout(() => (btn.textContent = 'Copy'), 1600);
    });
  })();

  /* ---------- contact form -> Web3Forms ---------- */
  (() => {
    const form = document.querySelector('[data-contact]');
    if (!form) return;
    const status = form.querySelector('[data-status]');
    const button = form.querySelector('.send-btn');
    const subjectField = form.querySelector('[data-subject-field]');
    const subjectInput = form.querySelector('#subject');
    const defaultSubject = "Fractional PM — let's talk";

    const setStatus = (msg, kind) => {
      status.textContent = msg;
      status.dataset.kind = kind || '';
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Carry the visible subject into the submitted field, with a fallback.
      subjectField.value = subjectInput.value.trim() || defaultSubject;

      const label = button.textContent;
      button.disabled = true;
      button.textContent = 'Sending…';
      setStatus('', '');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          form.reset();
          setStatus("Thanks — your message is on its way. I'll be in touch.", 'ok');
        } else {
          setStatus(data.message || 'Something went wrong — please email me directly.', 'err');
        }
      } catch (_) {
        setStatus('Network error — please email me directly.', 'err');
      } finally {
        button.disabled = false;
        button.textContent = label;
      }
    });
  })();
</script>

<style>
  /* shared container */
  .topbar,
  .hero,
  .colset,
  .experience,
  .sayhi,
  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding-left: 40px;
    padding-right: 40px;
  }

  /* ---------- top bar ---------- */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 30px;
    padding-bottom: 30px;
  }
  .logo {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--ink);
  }
  .nav {
    display: flex;
    gap: 26px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.02em;
  }
  .nav a { color: var(--nav); }
  .nav a:hover { color: var(--ink); }

  /* ---------- hero ---------- */
  .hero {
    padding-top: 60px;
    padding-bottom: 84px;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 56px;
    align-items: center;
  }
  h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 52px;
    line-height: 1.12;
    letter-spacing: -0.015em;
    max-width: 640px;
  }
  /* min-width is set by JS to the widest word so the line never reflows */
  .cycle {
    display: inline-block;
    white-space: nowrap;
    text-align: left;
  }
  .cycle-word {
    display: inline-block;
    color: var(--accent);
    background: linear-gradient(rgba(255, 207, 71, 0.38), rgba(255, 207, 71, 0.38))
      left bottom / 100% 8px no-repeat;
  }
  .hero-sub {
    font-weight: 300;
    font-size: 19px;
    line-height: 1.6;
    color: var(--body);
    max-width: 560px;
    margin-top: 34px;
  }

  .portrait { position: relative; }
  .portrait-block {
    position: absolute;
    inset: 0;
    transform: translate(14px, 14px);
    border-radius: 16px;
    background: rgba(255, 207, 71, 0.55);
  }
  .portrait-frame {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 18px 44px rgba(22, 35, 63, 0.14);
  }
  .portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  /* ---------- motto marquee ---------- */
  .motto {
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    padding: 20px 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .motto-track {
    display: inline-flex;
    animation: marquee 80s linear infinite;
  }
  .motto-half {
    display: inline-flex;
    gap: 40px;
    flex-shrink: 0;
    padding-right: 40px;
  }
  .motto-item {
    font-family: var(--font-serif);
    font-size: 26px;
    display: inline-flex;
    gap: 40px;
    align-items: center;
  }
  .motto-item[data-tone='0'] { color: var(--yellow); }
  .motto-item[data-tone='1'] { color: var(--accent); }
  .motto-item[data-tone='2'] { color: var(--ink); }
  .motto-star { color: #b9c0d4; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .motto-track { animation: none; }
  }

  /* ---------- two-column sections ---------- */
  .colset {
    padding-top: 100px;
    padding-bottom: 40px;
    display: grid;
    grid-template-columns: 210px 1fr;
    gap: 40px;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    padding-top: 12px;
  }
  .colset-body { max-width: 660px; }
  .lead {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 26px;
    line-height: 1.45;
    margin-bottom: 26px;
    color: var(--ink);
  }
  .lead em {
    font-style: italic;
    color: var(--accent);
  }
  .body {
    font-weight: 300;
    font-size: 16px;
    line-height: 1.7;
    color: var(--body);
  }
  .body + .body { margin-top: 18px; }

  /* ---------- experience ---------- */
  .experience {
    padding-top: 90px;
    padding-bottom: 40px;
  }
  .section-head {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 40px;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .exp-row {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 28px;
    align-items: baseline;
    padding: 26px 0;
    border-top: 1px solid var(--hairline-strong);
  }
  .exp-row:last-child { border-bottom: 1px solid var(--hairline-strong); }
  .exp-when {
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.08em;
    color: var(--muted-3);
    white-space: nowrap;
  }
  .exp-when.accent { color: var(--accent); }
  .exp-role {
    font-weight: 500;
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .exp-note {
    font-style: italic;
    font-size: 16px;
    color: var(--muted-2);
  }
  .exp-company {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--ink);
    text-align: right;
    align-self: center;
  }
  .company-mark {
    color: var(--accent);
    font-weight: 500;
  }

  /* ---------- say hi ---------- */
  .sayhi {
    margin-top: 60px;
    padding-top: 90px;
    padding-bottom: 70px;
  }
  .sayhi-inner {
    border-top: 1px solid var(--hairline);
    padding-top: 70px;
  }
  .sayhi-lead {
    max-width: 780px;
    margin-bottom: 90px;
  }
  .sayhi-lead .eyebrow {
    padding-top: 0;
    margin-bottom: 24px;
  }
  .sayhi-head {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 40px;
    line-height: 1.08;
    margin-bottom: 22px;
  }
  .sayhi-head em {
    font-style: italic;
    color: var(--accent);
  }
  .sayhi-lead .hero-sub { margin-top: 0; max-width: 640px; }

  .approach { padding: 0; margin-bottom: 100px; }
  .approach-body { max-width: 720px; }
  .approach-row {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 26px 0;
    border-top: 1px solid var(--hairline-strong);
  }
  .approach-row:last-child { border-bottom: 1px solid var(--hairline-strong); }
  .approach-n {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
  }
  .approach-title {
    font-family: var(--font-serif);
    font-size: 23px;
    color: var(--ink);
    margin-bottom: 6px;
  }
  .approach-desc {
    font-weight: 300;
    font-size: 16px;
    line-height: 1.65;
    color: var(--body);
  }

  /* ---------- contact card ---------- */
  .sayhi .colset { padding: 0; }
  .card {
    max-width: 720px;
    background: var(--card);
    border-radius: 22px;
    padding: 14px 40px 40px;
  }
  .card-row {
    display: grid;
    grid-template-columns: 96px 1fr;
    align-items: center;
    gap: 16px;
    padding: 22px 0;
    border-bottom: 1px solid var(--hairline-soft);
  }
  .card-row--to { grid-template-columns: 96px 1fr auto; }
  .card-row--message {
    grid-template-columns: 96px 1fr;
    align-items: start;
    padding-bottom: 28px;
  }
  .card label {
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    color: var(--muted-3);
  }
  .card-row--message label { padding-top: 2px; }
  .card-to {
    font-size: 17px;
    color: var(--ink);
  }
  .card input,
  .card textarea {
    font-family: var(--font-sans);
    font-size: 17px;
    color: var(--ink);
    background: none;
    border: none;
    outline: none;
    width: 100%;
    min-width: 0; /* allow fields to shrink inside the grid on narrow screens */
  }
  .card textarea {
    line-height: 1.6;
    resize: vertical;
  }
  .copy-btn {
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 2px;
    transition: color 0.2s ease;
  }
  .copy-btn:hover { color: var(--ink); }
  .send-btn {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.04em;
    padding: 15px 34px;
    border-radius: 40px;
    background: var(--ink);
    color: #fff;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .send-btn:hover { background: var(--accent); }
  .send-btn:disabled { opacity: 0.6; cursor: default; }

  .card-send {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 28px;
  }
  .form-status {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
  }
  .form-status[data-kind='ok'] { color: var(--accent); }
  .form-status[data-kind='err'] { color: #b4341f; }

  /* honeypot — hidden from humans; bots that tick it get rejected */
  .hp { display: none; }

  /* ---------- footer ---------- */
  .footer {
    background: var(--footer-bg);
    color: #fff;
    margin-top: 40px;
