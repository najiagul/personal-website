---
import Base from '../layouts/Base.astro';

const work = [
  {
    when: '2024 — now',
    role: 'Product Manager, SAP',
    note: 'adoption & portfolio analytics, eval frameworks, and enabling PMs to make AI part of their everyday product work',
  },
  {
    when: '2022 — 24',
    role: 'Data Scientist & AI Consultant, IBM',
    note: 'end-to-end machine learning for enterprise clients — finding insights in their data and shipping models to production',
  },
  {
    when: '2024 — now',
    role: 'MS Data Science & AI, Saarland University',
    note: 'NLP, trustworthy ML, generative AI',
  },
];

const help = [
  {
    what: 'Immersion',
    how: 'the first weeks go deep into your product, users, and metrics — so everything after rests on your context',
  },
  {
    what: 'Find where users stall',
    how: 'interviews and your own usage data, turned into a ranked list of fixes your team can start on Monday',
  },
  {
    what: 'Specs that ship',
    how: 'small, tightly scoped releases, written so engineering can start building without a clarification round',
  },
  {
    what: 'Evals from day one',
    how: 'a runnable definition of "good" for every AI feature, so "did the model update help?" takes minutes to answer — and the suite keeps working for your team long after the engagement ends',
  },
  {
    what: 'Hands-on when it helps',
    how: "I don't stay in the doc — when the team is stretched, I build alongside your engineers: prototypes, eval pipelines, the plumbing around the model",
  },
];
---

<Base
  title="Najia Gul — fractional product manager for AI teams"
  description="Product manager, former data scientist. I work with early-stage AI teams as a fractional PM — and build the evals that show whether each release helped."
>
  <div class="sheet">
    <header class="fade" style="--stagger: 0">
      <span class="ident">
        <span class="name">Najia Gul</span>
        <span class="where">✦ Based in Germany</span>
      </span>
      <nav>
        <a href="mailto:najiagul.2000@gmail.com">email</a>
        <a href="https://www.linkedin.com/in/najia-gul">linkedin</a>
        <a href="https://github.com/najiagul">github</a>
      </nav>
    </header>

    <section class="intro fade" style="--stagger: 1">
      <div class="intro-text">
        <h1>I work where product meets&nbsp;AI.</h1>
        <p>
          I'm a fractional product manager for early-stage AI teams — and a former data
          scientist. Most AI products lose users in the gap between what people are trying to
          do and what the product actually helps them do. My work is finding that gap, closing
          it, and building the evals that show whether each release actually helped.
        </p>
      </div>
      <figure class="polaroid">
        <img
          class="photo"
          src="najia.jpg"
          alt="Najia Gul, sitting on a park bench under green trees"
          width="450"
          height="600"
        />
      </figure>
    </section>

    <section class="fade" style="--stagger: 2">
      <span class="label">Work</span>
      <ul class="ledger">
        {
          work.map((w) => (
            <li>
              <span class="when">{w.when}</span>
              <span class="entry">
                <span class="role">{w.role}</span>
                <span class="note">{w.note}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="fade" style="--stagger: 3">
      <span class="label">Working together</span>
      <ul class="ledger">
        {
          help.map((h) => (
            <li>
              <span class="when what">{h.what}</span>
              <span class="entry">
                <span class="note">{h.how}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="outro fade" style="--stagger: 4">
      <span class="label">Contact</span>
      <p>
        Currently open to fractional engagements — write to me at
        <a href="mailto:najiagul.2000@gmail.com">najiagul.2000@gmail.com</a>.
      </p>
    </section>

    <footer class="fade" style="--stagger: 5">
      <span>© {new Date().getFullYear()} Najia Gul</span>
    </footer>
  </div>
</Base>

<style>
  .sheet {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 26px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 34px 0;
  }
  .ident { display: flex; flex-direction: column; gap: 2px; }
  .name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: 0.005em;
  }
  .where {
    font-size: 0.78rem;
    color: var(--soft);
    letter-spacing: 0.02em;
  }
  nav { display: flex; gap: 22px; }
  nav a {
    font-size: 0.88rem;
    text-decoration: none;
    color: var(--soft);
  }
  nav a:hover { color: var(--ink); text-decoration: underline; text-underline-offset: 4px; }

  .intro {
    padding: 12vh 0 0;
    display: flex;
    align-items: flex-start;
    gap: 44px;
  }
  .intro-text { flex: 1; }
  /* polaroid: white card, thicker bottom lip, soft shadow, gentle tilt */
  .polaroid {
    flex-shrink: 0;
    width: 196px;
    margin-top: 8px;
    padding: 11px 11px 34px;
    background: #fff;
    border: 1px solid var(--hairline);
    box-shadow:
      0 12px 28px rgba(26, 24, 21, 0.15),
      0 2px 6px rgba(26, 24, 21, 0.08);
    transform: rotate(-2.4deg);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .polaroid:hover {
    transform: rotate(0deg) scale(1.015);
    box-shadow:
      0 18px 40px rgba(26, 24, 21, 0.18),
      0 3px 8px rgba(26, 24, 21, 0.1);
  }
  .intro :global(.photo) {
    width: 100%;
    height: auto;
  }
  h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.9rem, 4.6vw, 2.7rem);
    line-height: 1.22;
    letter-spacing: -0.012em;
    text-wrap: balance;
  }
  .intro p {
    margin-top: 26px;
    font-size: 1.02rem;
    color: var(--ink);
    max-width: 60ch;
  }

  section + section { margin-top: 76px; }
  .intro + section { margin-top: 88px; }

  .ledger {
    list-style: none;
    margin-top: 18px;
  }
  .ledger li {
    display: grid;
    grid-template-columns: 168px 1fr;
    gap: 20px;
    padding: 16px 0;
    border-top: 1px solid var(--hairline);
  }
  .ledger li:last-child { border-bottom: 1px solid var(--hairline); }
  .when {
    font-size: 0.88rem;
    color: var(--soft);
    padding-top: 2px;
    font-variant-numeric: tabular-nums;
  }
  .when.what {
    color: var(--ink);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .entry { display: flex; flex-direction: column; gap: 4px; }
  .role { font-weight: 600; font-size: 0.98rem; }
  .note { font-size: 0.92rem; color: var(--soft); max-width: 52ch; }

  .outro p {
    margin-top: 18px;
    font-size: 1.02rem;
    max-width: 60ch;
  }

  footer {
    margin-top: auto;
    padding: 90px 0 36px;
    display: flex;
    justify-content: space-between;
    font-size: 0.82rem;
    color: var(--soft);
  }

  @media (max-width: 560px) {
    .intro { padding-top: 7vh; flex-direction: column-reverse; gap: 28px; }
    .polaroid { width: 168px; margin-top: 0; }
    section + section { margin-top: 56px; }
    .intro + section { margin-top: 64px; }
    .ledger li { grid-template-columns: 1fr; gap: 6px; }
    .when { padding-top: 0; }
    footer { padding-top: 64px; }
  }
</style>
