---
import Base from '../layouts/Base.astro';

const facts = [
  {
    num: '01',
    title: 'fractional pm — for ai teams',
    items: [
      'i help early-stage teams ship ai features users actually adopt',
      'evals: i build the systems that measure whatever you ship',
    ],
  },
  {
    num: '02',
    title: 'product manager @ sap',
    items: [
      'portfolio analysis: adoption, churn, financials → quarterly decisions',
      'eval frameworks so engineering ships faster',
    ],
  },
  {
    num: '03',
    title: 'prev. data scientist & ai consultant @ ibm',
    items: [
      'ml end-to-end: ambiguous business question → production',
      '100m-row datasets for enterprise clients [telco, fmcg, banking]',
    ],
  },
  {
    num: '04',
    title: 'ms data science & ai',
    items: ['nlp, trustworthy ml, generative ai'],
  },
];

const skills = [
  'product strategy',
  'ai evals',
  'user research',
  'data storytelling',
  'shipping with engineers',
];
---

<Base
  title="Najia Gul — fractional product manager for AI teams"
  description="product manager & former data scientist. i help early-stage teams ship ai features users actually adopt — with evals to measure whatever ships."
>
  <div class="page">
    <header>
      <span class="name">NAJIA GUL</span>
      <nav>
        <a href="https://www.linkedin.com/in/najia-gul">LINKEDIN</a>
        <a href="https://github.com/najiagul">GITHUB</a>
        <a href="mailto:najiagul.2000@gmail.com">EMAIL</a>
      </nav>
    </header>

    <div class="grid">
      <div class="col col-left">
        <h1 class="fade" style="--stagger: 0">hi!<br />i'm najia.</h1>
        <p class="thesis fade" style="--stagger: 1">
          i think deeply about the gap between what users want to achieve &amp; how easily ai
          products let them — and i believe you can't close a gap you don't measure.
        </p>
        <ul class="skills fade" style="--stagger: 3">
          {skills.map((s) => <li>{s}</li>)}
        </ul>
      </div>

      <div class="col col-mid fade" style="--stagger: 1">
        <p class="opener">i'm a pm who used to build the models</p>
        {
          facts.map((f) => (
            <section class="fact">
              <h2>
                <span class="num">[{f.num}]</span> {f.title}
              </h2>
              <ul>
                {f.items.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          ))
        }
        <!--
          photo slot: drop an image into public/ (e.g. public/najia.jpg) and add here:
          <img class="photo" src="/najia.jpg" alt="Najia Gul" />
        -->
      </div>

      <div class="col col-right fade" style="--stagger: 2">
        <p class="avail">◆ available for fractional work :)</p>
        <p class="based">☆ based in germany</p>
        <div class="contact">
          <a href="mailto:najiagul.2000@gmail.com">najiagul.2000@gmail.com</a>
          <span class="copy">© {new Date().getFullYear()}</span>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .page {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 36px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 0 22px;
  }
  .name {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }
  nav { display: flex; gap: 28px; }
  nav a {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-decoration: none;
  }
  nav a:hover { text-decoration: underline; text-underline-offset: 4px; }

  .grid {
    flex: 1;
    display: grid;
    grid-template-columns: 1.1fr 1.25fr 0.85fr;
    align-items: stretch;
  }

  .col { padding: 48px 0 40px; }
  .col-left {
    display: flex;
    flex-direction: column;
    padding-right: 44px;
  }
  .col-mid {
    border-left: 1px solid var(--hairline);
    border-right: 1px solid var(--hairline);
    padding-left: 44px;
    padding-right: 44px;
  }
  .col-right {
    display: flex;
    flex-direction: column;
    padding-left: 44px;
  }

  /* ---- left ---- */
  h1 {
    font-size: clamp(3.2rem, 6.5vw, 5.4rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.04em;
  }
  .thesis {
    margin-top: 40px;
    font-size: 0.98rem;
    max-width: 34ch;
    color: var(--ink);
  }
  .skills {
    list-style: none;
    margin-top: auto;
    padding-top: 56px;
    max-width: 360px;
  }
  .skills li {
    border-top: 1px solid var(--hairline);
    padding: 10px 0;
    font-size: 0.95rem;
  }
  .skills li:last-child { border-bottom: 1px solid var(--hairline); }

  /* ---- middle ---- */
  .opener { font-size: 0.95rem; color: var(--soft); }
  .fact { margin-top: 34px; }
  .fact h2 {
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.4;
  }
  .fact .num { font-weight: 700; margin-right: 2px; }
  .fact ul { list-style: none; margin-top: 8px; }
  .fact li {
    font-size: 0.95rem;
    line-height: 1.55;
    padding-left: 22px;
    position: relative;
    margin-top: 6px;
  }
  .fact li::before {
    content: '◉';
    position: absolute;
    left: 0;
    top: 0.05em;
    font-size: 0.8em;
  }

  /* ---- right ---- */
  .avail { font-size: 0.95rem; }
  .based { font-size: 0.95rem; margin-top: 14px; }
  .contact {
    margin-top: auto;
    padding-top: 56px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 0.92rem;
  }
  .copy { color: var(--soft); }

  /* ---- mobile ---- */
  @media (max-width: 900px) {
    .page { padding: 0 22px; }
    nav { gap: 18px; }
    .grid { display: flex; flex-direction: column; }
    .col { padding: 0; }
    .col-left { display: contents; }
    h1 { order: 1; padding-top: 28px; }
    .thesis { order: 2; margin-top: 24px; }
    .col-mid {
      order: 3;
      border: none;
      border-top: 1px solid var(--hairline);
      margin-top: 40px;
      padding: 32px 0 8px;
    }
    .opener { margin-top: 0; }
    .col-right {
      order: 4;
      border-top: 1px solid var(--hairline);
      margin-top: 36px;
      padding: 32px 0 0;
    }
    .skills {
      order: 5;
      margin-top: 44px;
      padding-top: 0;
      max-width: none;
      margin-bottom: 40px;
    }
    .contact { padding-top: 36px; }
  }
</style>
