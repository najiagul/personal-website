---
import Base from '../layouts/Base.astro';

const work = [
  {
    when: '2024 — now',
    role: 'Product Manager, SAP',
    note: 'adoption, churn & portfolio analytics; eval frameworks that let engineering ship faster',
  },
  {
    when: '2022 — 24',
    role: 'Data Scientist & AI Consultant, IBM',
    note: 'machine learning end-to-end for enterprise clients — from ambiguous question to production',
  },
  {
    when: '2024 — now',
    role: 'MS Data Science & AI, Saarland University',
    note: 'NLP, trustworthy ML, generative AI',
  },
];

const help = [
  {
    what: 'Find where users stall',
    how: 'interviews and your own usage data, turned into a ranked list of fixes your team can start on Monday',
  },
  {
    what: 'Ship at product-org cadence',
    how: 'small releases, clear specs, tight loops with engineering — without the enterprise bureaucracy',
  },
  {
    what: 'Measure everything',
    how: 'a runnable definition of "good" for every AI feature, so "did the model update help?" takes minutes to answer, not a meeting',
  },
];
---

<Base
  title="Najia Gul — fractional product manager for AI teams"
  description="Product manager, former data scientist. I work with early-stage AI teams as a fractional PM — and build the evals that show whether each release helped."
>
  <div class="sheet">
    <header class="fade" style="--stagger: 0">
      <span class="name">Najia Gul</span>
      <nav>
        <a href="mailto:najiagul.2000@gmail.com">email</a>
        <a href="https://www.linkedin.com/in/najia-gul">linkedin</a>
        <a href="https://github.com/najiagul">github</a>
      </nav>
    </header>

    <section class="intro fade" style="--stagger: 1">
      <h1>I'm a product manager who used to build the&nbsp;models.</h1>
      <p>
        I work with early-stage AI teams as a fractional PM. Most AI products lose their users
        in the distance between what someone came to do and what the product made them do
        instead — my work is finding that distance, closing it, and building the evals that
        show whether each release actually helped.
      </p>
    </section>

    <section class="fade" style="--stagger: 2">
      <span class="label">Work</span>
      <ul class="ledger">
        {
          work.map((w) => (
            <li>
              <span class="when">{w.when}</span>
              <span class="entry">
                <span class="role">{w.role}</span>
                <span class="note">{w.note}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="fade" style="--stagger: 3">
      <span class="label">For your team</span>
      <ul class="ledger">
        {
          help.map((h) => (
            <li>
              <span class="when what">{h.what}</span>
              <span class="entry">
                <span class="note">{h.how}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="outro fade" style="--stagger: 4">
      <span class="label">Contact</span>
      <p>
        If you're building with AI and want a PM who can argue with both the designer and the
        model, write to me — <a href="mailto:najiagul.2000@gmail.com">najiagul.2000@gmail.com</a>.
        Currently open to fractional engagements.
      </p>
    </section>

    <!--
      photo: drop an image into public/ (e.g. public/najia.jpg) and add inside .intro
      (keep the path relative so it works on staging and the real domain):
      <img class="photo" src="najia.jpg" alt="Najia Gul" />
    -->

    <footer class="fade" style="--stagger: 5">
      <span>© {new Date().getFullYear()}</span>
      <span>Saarbrücken, Germany</span>
    </footer>
  </div>
</Base>

<style>
  .sheet {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 26px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 34px 0;
  }
  .name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: 0.005em;
  }
  nav { display: flex; gap: 22px; }
  nav a {
    font-size: 0.88rem;
    text-decoration: none;
    color: var(--soft);
  }
  nav a:hover { color: var(--ink); text-decoration: underline; text-underline-offset: 4px; }

  .intro { padding: 12vh 0 0; }
  h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.9rem, 4.6vw, 2.7rem);
    line-height: 1.22;
    letter-spacing: -0.012em;
    text-wrap: balance;
  }
  .intro p {
    margin-top: 26px;
    font-size: 1.02rem;
    color: var(--ink);
    max-width: 60ch;
  }

  section + section { margin-top: 76px; }
  .intro + section { margin-top: 88px; }

  .ledger {
    list-style: none;
    margin-top: 18px;
  }
  .ledger li {
    display: grid;
    grid-template-columns: 168px 1fr;
    gap: 20px;
    padding: 16px 0;
    border-top: 1px solid var(--hairline);
  }
  .ledger li:last-child { border-bottom: 1px solid var(--hairline); }
  .when {
    font-size: 0.88rem;
    color: var(--soft);
    padding-top: 2px;
    font-variant-numeric: tabular-nums;
  }
  .when.what {
    color: var(--ink);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .entry { display: flex; flex-direction: column; gap: 4px; }
  .role { font-weight: 600; font-size: 0.98rem; }
  .note { font-size: 0.92rem; color: var(--soft); max-width: 52ch; }

  .outro p {
    margin-top: 18px;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.45;
    max-width: 34em;
  }

  footer {
    margin-top: auto;
    padding: 90px 0 36px;
    display: flex;
    justify-content: space-between;
    font-size: 0.82rem;
    color: var(--soft);
  }

  @media (max-width: 560px) {
    .intro { padding-top: 7vh; }
    section + section { margin-top: 56px; }
    .intro + section { margin-top: 64px; }
    .ledger li { grid-template-columns: 1fr; gap: 6px; }
    .when { padding-top: 0; }
    footer { padding-top: 64px; }
  }
</style>
